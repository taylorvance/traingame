{
  "name": "traingame",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist coverage .vite .eslintcache *.tsbuildinfo",
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "verify": "npm run lint && npm run test && npm run build",
    "verify:push": "npm run verify",
    "prepare": "simple-git-hooks",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "playtest:report": "node --experimental-transform-types scripts/playtest-report.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run verify:push"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@taylorvance/tv-shared-web": "^0.7.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@taylorvance/tv-shared-dev": "^0.1.1",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.16"
  }
}
